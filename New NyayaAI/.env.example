# Groq API — Get free key: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Embeddings Model — No key needed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Groq Model — Free model
GROQ_MODEL=llama-3.3-70b-versatile

# Groq Vision Model — Photo/document analysis ke liye (FIR, challan, notice)
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# ChromaDB Path — Local path
CHROMA_DB_PATH=ai/data/chroma_db

# RAG Settings
TOP_K_RESULTS=3

# App Settings
APP_NAME=NyayaAI
APP_VERSION=1.0.0
